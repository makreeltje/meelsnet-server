{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "docker:enableMajor", ":dependencyDashboard"],
  "dependencyDashboard": true,
  "prConcurrentLimit": 0,
  "separateMinorPatch": true,
  "separateMajorMinor": true,
  "separateMultipleMajor": true,
  "commitMessagePrefix": "[{{parentDir}}]",
  "additionalBranchPrefix": "{{parentDir}}-",
  "ignorePaths": ["compose/archive/**", "compose/game-servers/**"],
  "docker-compose": {
    "managerFilePatterns": [
      "/(^|/)compose\..*\.ya?ml$/",
      "/(^|/)compose\.ya?ml$/",
      "/(^|/)lxc/.*/compose\.ya?ml$/"
    ]
  },
 
  "packageRules": [
    {
      "description": "Automerge patch updates instantly",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr",
      "schedule": ["at any time"]
    },
    {
      "description": "Major and minor versions require manual review",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["major", "minor"],
      "automerge": false,
      "labels": ["major-update", "needs-review"]
    },
    {
      "description": "Infra services always require manual review",
      "matchDatasources": ["docker"],
      "matchFileNames": [
        "compose/reverse-proxy/**",
        "compose/database/**"
      ],
      "automerge": false,
      "labels": ["infra", "needs-review"]
    }
  ],
 
  "labels": ["renovate", "dependencies"]
}
