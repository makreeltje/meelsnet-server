{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "docker:enableMajor", ":dependencyDashboard"],
 
  "docker-compose": {
    "fileMatch": [
      "(^|/)compose\\..*\\.ya?ml$",
      "(^|/)compose\\.ya?ml$",
      "(^|/)lxc/.*/compose\\.ya?ml$"
    ]
  },
 
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)\\.env\\.example$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)\\n[A-Z_]+=(?<currentValue>.+)"
      ],
      "datasourceTemplate": "{{datasource}}"
    }
  ],
 
  "packageRules": [
    {
      "description": "Automerge patch and minor updates instantly",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "pr",
      "schedule": ["at any time"]
    },
    {
      "description": "Major versions require manual review",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["major-update", "needs-review"]
    },
    {
      "description": "Infra services always require manual review",
      "matchDatasources": ["docker"],
      "matchFileNames": [
        "compose/reverse-proxy/**",
        "compose/database/**"
      ],
      "automerge": false,
      "labels": ["infra", "needs-review"]
    }
  ],
 
  "labels": ["renovate", "dependencies"]
}