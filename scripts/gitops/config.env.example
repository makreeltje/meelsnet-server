# =============================================================================
# GitOps Controller Configuration
# =============================================================================
# Copy this file to /etc/gitops/config.env on Proxmox and adjust values.

# Git repository (use SSH with a read-only deploy key)
REPO_URL=git@github.com:makreeltje/meelsnet-server.git

# Local clone directory on Proxmox
REPO_DIR=/opt/gitops/meelsnet-server

# Branch to track
BRANCH=main

# State directory (tracks last deployed commit per LXC)
STATE_DIR=/opt/gitops/state

# Log directory
LOG_DIR=/var/log/gitops

# Docker base directory inside each LXC
DOCKER_BASE=/root/docker

# Webhook listener port
WEBHOOK_PORT=9000

# Webhook secret (MUST match the secret configured in GitHub)
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=
